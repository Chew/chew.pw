<h1>New York Times' Connections Answers</h1>

<p>The answer to every NYT Connections puzzle!!!</p>

<a href="https://www.nytimes.com/games/connections" class="btn btn-primary">Play Game!</a>

<% if params[:date].nil? %>
  <a id="connectionsAnswer" class="btn btn-danger">Click To See Today's Answer</a>
<% end %>

<hr>

<% if params[:date] %>
  <div class="row">
    <% @data['categories'].each do |category| %>
      <div class="col-md-6 col-lg-3">
        <strong><%= category['title'] %></strong><br>
        <ul>
          <% category['cards'].each do |answer| %>
            <li><%= answer['content'].titleize %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
<% else %>
  <p>Please click the button above to show the answers.</p>
<% end %>